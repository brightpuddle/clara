# Clara server configuration
# Install to: ~/.config/clara/server.yaml
# All values can be overridden with environment variables (listed in comments).

db:
  # PostgreSQL connection string.
  # Env: CLARA_DB_DSN
  dsn: "postgres://clara:clara@localhost:5432/clara?sslmode=disable"

ai:
  # Embedding/LLM provider. Currently supported: "ollama", "openai"
  # Env: CLARA_AI_PROVIDER
  provider: "ollama"

  ollama:
    # Base URL for a locally-running Ollama instance.
    # Ollama MUST run natively (brew install ollama) on macOS to use Apple
    # Silicon GPU (Metal). Do NOT run Ollama in Docker — no GPU passthrough.
    # Env: CLARA_OLLAMA_URL
    base_url: "http://localhost:11434"
    # Embedding model to use. nomic-embed-text produces 768-dim vectors and
    # runs well on Apple Silicon. Pull with: ollama pull nomic-embed-text
    # Env: CLARA_OLLAMA_EMBED_MODEL
    embed_model: "nomic-embed-text"

  openai:
    # Set provider: "openai" above to use OpenAI embeddings instead of Ollama.
    # Tradeoffs: higher capability, higher latency, subscription cost, no local
    # hardware requirement.
    # Env: CLARA_OPENAI_API_KEY
    api_key: ""
    # Env: CLARA_OPENAI_EMBED_MODEL
    embed_model: "text-embedding-3-small"
    # Override to use Azure OpenAI, a local vLLM server, or Ollama's OpenAI-
    # compatible endpoint (/v1). Leave empty for the default OpenAI API URL.
    # Env: CLARA_OPENAI_BASE_URL
    base_url: ""

temporal:
  # Temporal gRPC address (started by docker compose).
  # Env: CLARA_TEMPORAL_HOST
  host: "localhost:7233"

grpc:
  # gRPC listen address for the agent.
  # Env: CLARA_GRPC_ADDR
  addr: ":50051"

http:
  # REST API + web UI listen address.
  # Env: CLARA_HTTP_ADDR
  addr: ":8080"

# Clara Configuration Example
#
# Copy to ~/.config/clara/config.yaml and customize.
# String values support ${ENV_VAR} expansion.

# Log level: trace, debug, info, warn, error (default: info)
log_level: info

# Override the default runtime data directory
# (default: ~/.local/share/clara)
# data_dir: /custom/path/clara

# Additional search paths used to resolve bare MCP server commands like `clara`,
# `uvx`, or tools installed with `go install` when Clara runs under launchd.
# These paths are prepended to the normal PATH lookup; common local defaults
# such as /usr/local/bin and /opt/homebrew/bin are also included automatically.
# mcp_command_search_paths:
#   - ${HOME}/go/bin
#   - /custom/tools/bin
 
# MCP services managed by the Clara daemon.
# Every intent-visible capability should be exposed via one of these services,
# including built-in Clara services like filesystem, SQLite, and macOS bridge tools.
mcp_servers:
  - name: fs
    command: clara
    args:
      - mcp
      - fs
    description: "Built-in filesystem server (read, write, list, search, move, delete files)"

  - name: db
    command: clara
    args:
      - mcp
      - db
      - ${HOME}/.local/share/clara/data.db
    description: "Built-in SQLite tool server for user-facing query/exec/vector tools"

  - name: ollama
    command: clara
    args:
      - mcp
      - ollama
      - --url
      - http://localhost:11434
    description: "Built-in Ollama generation and embeddings server"

  - name: llm
    command: clara
    args:
      - mcp
      - llm
      - --gemini-model
      - gemini-2.5-flash
    env:
      GEMINI_API_KEY: ${GEMINI_API_KEY}
    description: "Built-in Gemini-backed LLM server for text and vision generation"

  - name: bridge
    command: /usr/local/bin/ClaraBridge
    args: []
    description: "Native macOS MCP server (EventKit, notifications, reminder/event wait tools, and other local capabilities); the wrapper should exec the app-bundled bridge binary"

  - name: filesystem
    command: npx
    args:
      - "-y"
      - "@modelcontextprotocol/server-filesystem"
      - "${HOME}/Documents"
    description: "External filesystem MCP server for ~/Documents"

  - name: taskwarrior
    command: clara
    args:
      - mcp
      - taskwarrior
    description: "Built-in Taskwarrior MCP server for CRUD, filtering, and due-task checks"

  - name: openai-embedder
    command: uvx
    args:
      - mcp-nomic-embed
    env:
      NOMIC_API_KEY: ${NOMIC_API_KEY}
    description: "Nomic text embedding server"

   # Chrome browser automation via the built-in clara mcp chrome server.
  #
  # The chrome MCP server bridges browser tool calls to the Clara Chrome
  # extension over a local WebSocket on port 48765. No native messaging
  # registration is required.
  #
  # One-time setup:
  #   1. make install          — installs the clara binary
  #   2. Load the extension:
  #        chrome://extensions/ → enable Developer mode → Load unpacked →
  #        select the extension/ directory in the Clara repo (or install dir)
  #
  # After that, start Clara — the chrome server starts automatically as a
  # subprocess, and the extension connects to it when Chrome is running.
  # If the extension connects before Clara starts, it reconnects automatically.
  #
  # - name: chrome
  #   command: clara
  #   args: [mcp, chrome]
  #   description: >
  #     Chrome browser automation (navigate, click, fill, upload files,
  #     screenshot, read page content). Used by Facebook Marketplace,
  #     Messenger, and other web automation intents.

# Clara Configuration Example
#
# Copy to ~/.config/clara/config.yaml and customize.
# String values support ${ENV_VAR} expansion.

# Log level: trace, debug, info, warn, error (default: info)
log_level: info

# Data directory for internal storage (default: ~/.local/share/clara)
# data_dir: ~/.local/share/clara

# Directory where .star intent files are watched (default: ~/.config/clara/tasks)
# tasks_dir: ~/.config/clara/tasks

# ── MCP Servers ───────────────────────────────────────────────────────────────
# Clara manages their lifecycle and exposes their tools to Starlark.
# The server name becomes the namespace prefix for its tools (e.g. github.search_repositories).
#
# How to use in Starlark:
#   result = github.search_repositories({"query": "clara"})
#
# Maximum time to wait for servers to be ready at startup (default: 30s).
# mcp_startup_timeout: 30s
#
# Additional directories to search for MCP server binaries (e.g. npm global installs).
# mcp_command_search_paths:
#   - /usr/local/bin
#   - /opt/homebrew/bin

mcp_servers:
  # GitHub integration via the official GitHub MCP server.
  # Install: npm install -g @modelcontextprotocol/server-github
  # - name: github
  #   command: github-mcp-server stdio
  #   env:
  #     GITHUB_PERSONAL_ACCESS_TOKEN: "${GITHUB_TOKEN}"

  # Any streamable HTTP MCP server.
  # - name: my-service
  #   url: http://localhost:8080/mcp
  #   token: "${MY_SERVICE_TOKEN}"
  #   description: "My custom MCP service"

# ── Notification backend ───────────────────────────────────────────────────────
# Controls how notify.send and notify.ask deliver messages to you.
#
# Backends: dummy (default) | macos | webex | discord
#
#   dummy   — logs messages to the daemon log; notify.ask returns "acknowledged"
#             immediately. Safe default that requires no configuration.
#
#   macos   — uses the macOS ClaraBridge integration for native notifications.
#
#   webex   — bot posts to a Webex room; notify.ask pauses the script and
#             resumes when the bot webhook receives a reply.
#
#   discord — same shape as webex but uses a Discord channel.
#
notify:
  backend: dummy  # dummy | macos | webex | discord
  # webex:
  #   bot_token: "${WEBEX_BOT_TOKEN}"
  #   room_id:   "${WEBEX_NOTIFY_ROOM_ID}"
  # discord:
  #   bot_token:  "${DISCORD_BOT_TOKEN}"
  #   channel_id: "${DISCORD_NOTIFY_CHANNEL_ID}"

# ── Integrations ───────────────────────────────────────────────────────────────
# Configures the native Go plugins.
integrations:
  # SQLite database integration
  db:
    path: "${HOME}/.local/share/clara/data.db"

  # Zettelkasten/Obsidian vault integration
  zk:
    vault_root: "${HOME}/Documents/Notes"
    # Optional FTS5 search index path
    # index_path: "${HOME}/.local/share/clara/zk_search.db"

  # Filesystem integration
  # fs: {}

  # Shell execution integration
  # shell: {}

  # Chrome browser automation
  # chrome: {}

  # LLM multiplexer — routes llm.generate / llm.embed calls to providers.
  #
  # Each category maps to an ordered list of models; Clara tries them in
  # order and falls back to the next on error.  Provider names must match
  # a key under `providers`.
  #
  # Built-in provider names: ollama | gemini | openai
  # Any openai-compatible API (LM Studio, vLLM, …) can use provider: openai
  # with a custom base_url.
  #
  # Starlark usage:
  #   result = llm.generate({"category": "fast", "message": "Hello!"})
  #   print(result["message"]["content"])
  #
  #   # Multi-turn:
  #   result = llm.generate({
  #     "category": "reasoning",
  #     "messages": [
  #       {"role": "system", "content": "You are a concise assistant."},
  #       {"role": "user",   "content": "Explain goroutines in one sentence."},
  #     ],
  #   })
  #
  # llm:
  #   providers:
  #     # Local Ollama instance (no API key required)
  #     ollama:
  #       base_url: http://localhost:11434
  #
  #     # Google Gemini
  #     gemini:
  #       api_key: "${GEMINI_API_KEY}"
  #
  #     # OpenAI (or any OpenAI-compatible endpoint)
  #     openai:
  #       base_url: https://api.openai.com/v1
  #       key: "${OPENAI_API_KEY}"
  #
  #     # LM Studio example (openai-compatible)
  #     lmstudio:
  #       base_url: http://localhost:1234/v1
  #
  #   categories:
  #     # Quick tasks: try Gemini Flash first, fall back to local Ollama
  #     fast:
  #       - provider: gemini
  #         model: gemini-2.0-flash
  #       - provider: ollama
  #         model: qwen3:8b
  #
  #     # Heavy reasoning tasks
  #     reasoning:
  #       - provider: gemini
  #         model: gemini-2.5-pro
  #       - provider: openai
  #         model: o4-mini
  #
  #     # Fully local — no network calls
  #     local:
  #       - provider: ollama
  #         model: qwen3-coder
  #
  #     # Vision tasks
  #     vision:
  #       - provider: gemini
  #         model: gemini-2.0-flash
  #
  #     # Embeddings
  #     embeddings:
  #       - provider: ollama
  #         model: nomic-embed-text

# ── Starlark lib/ convention ───────────────────────────────────────────────────
# Place shared Starlark modules under ~/.config/clara/tasks/lib/ so any intent
# can load them with:
#
#   load("lib/task.star", "add", "list")
#   load("lib/search.star", "query")
#
# Two example stubs are documented below.  Copy and edit them to match your
# preferred backends — changing the implementation in one lib file updates
# every intent that loads it.
#
# lib/task.star example:
#
#   def add(description, project="", priority="", due=""):
#       args = {"description": description}
#       if project:  args["project"]  = project
#       if priority: args["priority"] = priority
#       if due:      args["due"]      = due
#       return task.add(args)
#
#   def list(filter=""):
#       return task.list({"filter": filter})
#
#   def complete(id):
#       return task.done({"id": id})
#
# lib/search.star example:
#
#   def query(q, sources=["web", "zk"]):
#       results = []
#       if "web" in sources:
#           results += web.search({"query": q}).get("results", [])
#       if "zk" in sources:
#           results += zk.search({"query": q}).get("notes", [])
#       return results

